# Production Environment Variables
# Copy this file to .env.production and adjust values for your deployment

# Backend API URL (without trailing slash)
# For Docker Compose setup with backend in same network: http://central-manager:8000/api/v1
# For standalone with backend on same host: http://localhost:8000/api/v1
# For production with separate domain: https://api.example.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Payment gateway redirect URLs (frontend URLs)
# These should point to your frontend domain
VITE_PAYMENT_SUCCESS_URL=https://vpn-user.example.com/payment/success
VITE_PAYMENT_FAIL_URL=https://vpn-user.example.com/payment/fail

# Application title
VITE_APP_TITLE=VPN User Panel

# Enable mock authentication (for development only)
# Set to false in production to use real backend authentication
VITE_MOCK_AUTH=false

# Optional: Backend API key for admin operations (if needed for certain endpoints)
# VITE_API_KEY=your-api-key-here

# Optional: Platega.io payment gateway configuration
# VITE_PAYMENT_GATEWAY_URL=https://api.platega.io
# VITE_PAYMENT_GATEWAY_KEY=your-payment-gateway-key