# For development with Vite proxy (recommended):
VITE_API_BASE_URL=/api/v1

# For production or direct connection:
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# Payment redirect URLs (used after payment gateway returns)
VITE_PAYMENT_SUCCESS_URL=http://localhost:9556/payment/success
VITE_PAYMENT_FAIL_URL=http://localhost:9556/payment/fail

# Application title
VITE_APP_TITLE=VPN User Panel

# Mock authentication (set to true to bypass real auth while backend not ready)
VITE_MOCK_AUTH=false